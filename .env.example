# ======================
# 客服消息桥接 — 环境配置
# 部署前复制为 .env 并填写
# ======================

PORT=3000

# ─── 飞书自定义机器人 ───
# 在飞书群 → 设置 → 群机器人 → 添加自定义机器人 → 复制 Webhook URL
# 格式：https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/你的WebhookID

# ─── Facebook Messenger ───
# 在 Facebook Developer Console → Webhook 设置时使用的验证 Token
# 自己随便写一个复杂字符串即可，如：fb_webhook_2024_abc123
FB_VERIFY_TOKEN=这里填你自定义的验证Token

# 可选：Facebook Page Access Token
# 用于显示客户名称而不是数字 ID。需要从 Facebook Developer 生成
# 不填也能用，只是客户显示为 user_数字ID
FB_PAGE_ACCESS_TOKEN=

# ─── Line Messaging API ───
# 在 Line Developer Console → Messaging API 频道 → Basic Settings 里找到
LINE_CHANNEL_SECRET=你的Line Channel Secret

# 可选：Line Channel Access Token
# 用于显示客户名称。在 Line Developer Console → Messaging API → 生成
LINE_CHANNEL_ACCESS_TOKEN=
